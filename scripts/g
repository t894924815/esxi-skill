#!/usr/bin/env bash
# g — govc wrapper.
#
# THREAT MODEL / WHAT THIS SCRIPT DOES AND DOES NOT PROTECT:
#
#   govc itself only accepts credentials via GOVC_PASSWORD env var, a
#   `user:pass@host` URL arg, or a plaintext ~/.govmomirc. All three
#   involve the password reaching govc somehow. This wrapper picks the
#   least-bad option (env var) and does three things to minimize exposure:
#
#     1. No GOVC_PASSWORD variable is ever set in THIS wrapper's shell.
#        The password flows: keychain CLI stdout → command substitution
#        → `env GOVC_PASSWORD=... govc` argv → execve() → govc env.
#
#     2. `env -i` strips all other inherited env before exec, so only
#        PATH/HOME/USER + GOVC_* are passed to govc. Smaller attack
#        surface for any subprocess govc may spawn.
#
#     3. `exec` replaces the wrapper's process with govc, so the wrapper
#        shell does not remain alive holding the password in RAM.
#
#   What this does NOT protect against:
#     - The password IS in govc's own process environment for the duration
#       of govc's execution. Another process with the same UID (or root)
#       can read /proc/<govc-pid>/environ or attach via ptrace/DTrace.
#     - If govc crashes with core dumps enabled, the password may appear
#       in the core file. Disable core dumps (ulimit -c 0) or avoid on
#       shared hosts.
#
# Credential lookup order:
#   macOS:   security find-generic-password (login Keychain)
#   Linux:   secret-tool lookup → ~/.config/esxi-skill/<profile>.cred
#   Other:   ~/.config/esxi-skill/<profile>.cred (chmod 600)
#
# Profile: ESXI_PROFILE env var (default "default").
#
# Usage: g <govc-args...>

set -euo pipefail

PROFILE="${ESXI_PROFILE:-default}"
CONF_FILE="$HOME/.config/esxi-skill/$PROFILE.env"

if [ ! -f "$CONF_FILE" ]; then
  echo "esxi-skill: profile '$PROFILE' not configured ($CONF_FILE missing)" >&2
  echo "  Ask your AI assistant to help set it up, or see: $(dirname "$0")/../references/setup-commands.md" >&2
  exit 2
fi

# shellcheck disable=SC1090
source "$CONF_FILE"

KEYCHAIN_SERVICE="${ESXI_CRED_SERVICE:-govc-$GOVC_URL}"

if ! command -v govc >/dev/null 2>&1; then
  echo "esxi-skill: govc not in PATH" >&2
  echo "  Install: brew install govc (macOS) or download from https://github.com/vmware/govmomi/releases" >&2
  exit 4
fi

# --- Build the keychain-lookup command for the current OS ---
# We invoke it via command substitution INSIDE the exec env assignment,
# so the password value goes: keychain CLI stdout → exec() argv → govc env.
# The wrapper's shell never stores the password in any variable.
case "$(uname)" in
  Darwin)
    # macOS: login Keychain
    if ! security find-generic-password \
           -a "$GOVC_USERNAME" -s "$KEYCHAIN_SERVICE" >/dev/null 2>&1; then
      echo "esxi-skill: password not found in Keychain (service=$KEYCHAIN_SERVICE account=$GOVC_USERNAME)" >&2
      echo "  See setup instructions: $(dirname "$0")/../references/setup-commands.md" >&2
      exit 3
    fi
    exec env -i \
      PATH="$PATH" HOME="$HOME" USER="$USER" \
      GOVC_URL="$GOVC_URL" \
      GOVC_USERNAME="$GOVC_USERNAME" \
      GOVC_INSECURE="$GOVC_INSECURE" \
      GOVC_DATACENTER="${GOVC_DATACENTER:-ha-datacenter}" \
      GOVC_PASSWORD="$(security find-generic-password -a "$GOVC_USERNAME" -s "$KEYCHAIN_SERVICE" -w)" \
      govc "$@"
    ;;

  Linux)
    # Linux: libsecret > file fallback
    if command -v secret-tool >/dev/null 2>&1 && \
       secret-tool lookup service "$KEYCHAIN_SERVICE" account "$GOVC_USERNAME" >/dev/null 2>&1; then
      exec env -i \
        PATH="$PATH" HOME="$HOME" USER="$USER" \
        GOVC_URL="$GOVC_URL" \
        GOVC_USERNAME="$GOVC_USERNAME" \
        GOVC_INSECURE="$GOVC_INSECURE" \
        GOVC_DATACENTER="${GOVC_DATACENTER:-ha-datacenter}" \
        GOVC_PASSWORD="$(secret-tool lookup service "$KEYCHAIN_SERVICE" account "$GOVC_USERNAME")" \
        govc "$@"
    fi
    CRED_FILE="$HOME/.config/esxi-skill/$PROFILE.cred"
    if [ -f "$CRED_FILE" ]; then
      # File read via command substitution; not via env/var in this shell.
      exec env -i \
        PATH="$PATH" HOME="$HOME" USER="$USER" \
        GOVC_URL="$GOVC_URL" \
        GOVC_USERNAME="$GOVC_USERNAME" \
        GOVC_INSECURE="$GOVC_INSECURE" \
        GOVC_DATACENTER="${GOVC_DATACENTER:-ha-datacenter}" \
        GOVC_PASSWORD="$(cat "$CRED_FILE")" \
        govc "$@"
    fi
    echo "esxi-skill: password not found in libsecret or $CRED_FILE" >&2
    exit 3
    ;;

  *)
    CRED_FILE="$HOME/.config/esxi-skill/$PROFILE.cred"
    if [ -f "$CRED_FILE" ]; then
      exec env -i \
        PATH="$PATH" HOME="$HOME" USER="$USER" \
        GOVC_URL="$GOVC_URL" \
        GOVC_USERNAME="$GOVC_USERNAME" \
        GOVC_INSECURE="$GOVC_INSECURE" \
        GOVC_DATACENTER="${GOVC_DATACENTER:-ha-datacenter}" \
        GOVC_PASSWORD="$(cat "$CRED_FILE")" \
        govc "$@"
    fi
    echo "esxi-skill: password not found at $CRED_FILE" >&2
    exit 3
    ;;
esac
