#!/usr/bin/env bash
# g — govc wrapper that auto-loads credentials from OS-native keychain.
#
# Credential lookup order:
#   macOS:  security find-generic-password (login Keychain)
#   Linux:  secret-tool lookup → ~/.config/esxi-skill/<profile>.cred
#   Other:  ~/.config/esxi-skill/<profile>.cred (chmod 600)
#
# Profile is selected via ESXI_PROFILE env var (default: "default").
#
# Usage:
#   g <govc-args...>

set -euo pipefail

PROFILE="${ESXI_PROFILE:-default}"
CONF_FILE="$HOME/.config/esxi-skill/$PROFILE.env"

if [ ! -f "$CONF_FILE" ]; then
  echo "esxi-skill: profile '$PROFILE' not configured ($CONF_FILE missing)" >&2
  echo "  Run setup: bash $(dirname "$0")/setup-interactive.sh" >&2
  exit 2
fi

# shellcheck disable=SC1090
source "$CONF_FILE"

# --- Load password from the appropriate backend ---
KEYCHAIN_SERVICE="${ESXI_CRED_SERVICE:-govc-$GOVC_URL}"
PW=""

case "$(uname)" in
  Darwin)
    PW=$(security find-generic-password \
           -a "$GOVC_USERNAME" -s "$KEYCHAIN_SERVICE" -w 2>/dev/null || true)
    if [ -z "$PW" ]; then
      echo "esxi-skill: password not found in Keychain" >&2
      echo "  Expected: service=$KEYCHAIN_SERVICE account=$GOVC_USERNAME" >&2
      echo "  Re-run: bash $(dirname "$0")/setup-interactive.sh" >&2
      exit 3
    fi
    ;;
  Linux)
    if command -v secret-tool >/dev/null 2>&1; then
      PW=$(secret-tool lookup service "$KEYCHAIN_SERVICE" account "$GOVC_USERNAME" 2>/dev/null || true)
    fi
    if [ -z "$PW" ]; then
      # Fall back to file-based credential (created by setup-interactive.sh)
      CRED_FILE="$HOME/.config/esxi-skill/$PROFILE.cred"
      if [ -f "$CRED_FILE" ]; then
        PW=$(< "$CRED_FILE")
      fi
    fi
    if [ -z "$PW" ]; then
      echo "esxi-skill: password not found in libsecret or cred file" >&2
      echo "  Re-run: bash $(dirname "$0")/setup-interactive.sh" >&2
      exit 3
    fi
    ;;
  *)
    CRED_FILE="$HOME/.config/esxi-skill/$PROFILE.cred"
    if [ -f "$CRED_FILE" ]; then
      PW=$(< "$CRED_FILE")
    else
      echo "esxi-skill: password not found" >&2
      exit 3
    fi
    ;;
esac

if ! command -v govc >/dev/null 2>&1; then
  echo "esxi-skill: govc not in PATH" >&2
  echo "  Install by re-running setup: bash $(dirname "$0")/setup-interactive.sh" >&2
  exit 4
fi

export GOVC_PASSWORD="$PW"
unset PW
exec govc "$@"
